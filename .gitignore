# Benchmark data
torchsparsegradutils/benchmarks/.benchmark_data/

# New benchmarks/ suite (spec/benchmarks.md §4: "JSON only, no dashboards"
# during migration) -- one JSON per run, machine-specific, never committed
# (spec/commit.md #11: "results/*.json from your test run are NOT
# committed"). Rendered charts are reproducible from those JSONs too.
benchmarks/results/
benchmarks/charts/

# cuda/ package build artifacts (spec/commit.md commit 10 / build.md:
# kernel-builder is Hub-only — nothing here is committed source).
cuda/result
cuda/build/
cuda/bench/build/
# create-pyproject's generated local-install/clang-tidy scaffold (CMakeLists,
# setup.py, pyproject.toml, torch-ext/registration.h, metadata-*.json) —
# regenerate on demand with `kernel-builder create-pyproject cuda cuda`.
cuda/CMakeLists.txt
cuda/cmake/
cuda/compat.py
cuda/setup.py
cuda/pyproject.toml
cuda/metadata-*.json
cuda/torch-ext/registration.h
cuda/torch-ext/*/_ops.py
cuda/torch-ext/*/*.so
cuda/.compile-commands/
cuda/bench/compile_commands.json
